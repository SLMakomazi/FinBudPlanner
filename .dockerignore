# Prevent local build artifacts from leaking into containers
**/node_modules/
frontend/node_modules/
frontend/dist/

# Ignore local Python artifacts
**/__pycache__/
**/*.pyc
backend/.pytest_cache/

# Ignore local database states and metrics
database/
**/*.db
**/*.jtl
jmeter-report/

# Ignore source control metadata
.git
.github
